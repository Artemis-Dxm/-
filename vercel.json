{
  "builds": [
    {
      "src": "api/upload.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "10mb" }
    },
    {
      "src": "api/understand.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/review.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/upload",
      "dest": "/api/upload.py"
    },
    {
      "src": "/api/understand",
      "dest": "/api/understand.py"
    },
    {
      "src": "/api/review",
      "dest": "/api/review.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/frontend",
      "dest": "/frontend/index.html"
    }
  ]
}
